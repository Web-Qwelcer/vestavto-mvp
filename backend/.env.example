# VestAvto MVP - Environment Variables

# === App ===
DEBUG=false
PORT=8000
FRONTEND_URL=https://vestavto-webapp.vercel.app

# === Database ===
# SQLite (development)
DATABASE_URL=sqlite+aiosqlite:///./vestavto.db
# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vestavto

# === Telegram ===
TELEGRAM_CLIENT_BOT_TOKEN=your_client_bot_token
TELEGRAM_MANAGER_BOT_TOKEN=your_manager_bot_token
TELEGRAM_MANAGER_CHAT_IDS=123456789

# === Auth ===
JWT_SECRET=change-this-to-random-string-in-production
ADMIN_USER=admin
ADMIN_PASS=change-this-password

# === Monobank ===
MONOBANK_API_TOKEN=your_monobank_token
MONOBANK_WEBHOOK_URL=https://your-domain.com/api/payments/webhook

# === Nova Poshta ===
NOVAPOSHTA_API_KEY=your_np_api_key
NP_SENDER_REF=your_sender_ref
NP_CONTACT_SENDER_REF=your_contact_sender_ref
NP_SENDER_PHONE=380XXXXXXXXX
NP_CITY_SENDER_REF=your_city_ref
NP_WAREHOUSE_SENDER_REF=your_warehouse_ref
